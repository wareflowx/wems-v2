{
  "appId": "com.wems",
  "productName": "WEMS",
  "directories": {
    "output": "dist",
    "buildResources": "build"
  },
  "files": ["out/**/*", "package.json"],
  "extraResources": [
    {
      "from": "src/core/db/migrations",
      "to": "migrations"
    }
  ],
  "asar": true,
  "asarUnpack": ["node_modules/better-sqlite3/**"],
  "win": {
    "target": ["portable"],
    "icon": "build/icon.ico"
  }
}
